# Local .terraform directories
**/.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Exclude all .tfvars files, which can contain sensitive data
*.tfvars
*.tfvars.json
!*.tfvars.example

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include tfplan files
*.tfplan

# CLI configuration files
.terraformrc
terraform.rc

# Python virtual environment & logs
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.log

# OS generated files
.DS_Store
Thumbs.db
